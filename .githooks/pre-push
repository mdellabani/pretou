#!/usr/bin/env bash
# Pre-push hook: run turbo typecheck across the monorepo.
# Cached runs are ~100ms, so this is cheap unless types actually changed.
# Bypass with: git push --no-verify

set -e

# Skip if no TS/TSX changes between upstream and HEAD.
upstream=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "")
if [ -n "$upstream" ]; then
  changed=$(git diff --name-only "$upstream"...HEAD -- '*.ts' '*.tsx' 'tsconfig*.json' 'package.json' 2>/dev/null || echo "")
  if [ -z "$changed" ]; then
    exit 0
  fi
fi

echo "→ Running turbo typecheck before push..."
pnpm turbo run typecheck
