# rural-community-platform Environment Variables
# Copy this file to .env.local and fill in the values

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Module: db-supabase ---
# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# Supabase anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...

# --- Module: monitoring ---
# PostHog project API key (Project Settings > Project Token)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
# PostHog instance host URL (EU region for French users)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# Secret for cron endpoint protection (openssl rand -hex 32)
CRON_SECRET=
# Supabase service role key (bypasses RLS — server-side only)
SUPABASE_SERVICE_ROLE_KEY=

# --- Module: feedback ---
# GitHub App ID for feedback integration
GITHUB_APP_ID=123456
# GitHub App private key (base64 encoded)
GITHUB_APP_PRIVATE_KEY=base64-encoded-private-key
# GitHub App installation ID
GITHUB_APP_INSTALLATION_ID=12345678
# GitHub repo for feedback issues (owner/repo)
FEEDBACK_REPO=myuser/myapp-feedback
