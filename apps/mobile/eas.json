{
  "cli": {
    "version": ">= 13.0.0",
    "requireCommit": false,
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "demo": {
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "demo"
      },
      "channel": "demo"
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "APP_VARIANT": "production"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
